{
  "name": "agent-delegate-repo",
  "private": true,
  "version": "0.1.0",
  "description": "MCP-first delegation advisor for coding agents.",
  "workspaces": [
    "packages/core",
    "packages/mcp-server",
    "packages/cli"
  ],
  "scripts": {
